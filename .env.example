HF_TOKEN=your_huggingface_token_here

# Optional: path to python.exe that has whisperx installed (if auto-detect fails)
# SENTINEL_PYTHON=C:\Users\You\AppData\Local\Microsoft\WindowsApps\PythonSoftwareFoundation.Python.3.13_qbz5n2kfra8p0\python.exe
# Shared secret — must match Kaggle notebook KAGGLE_SECRET
SENTINEL_SECRET=
KAGGLE_SECRET=
# ngrok URL printed when kaggle_gpu_server.ipynb finishes (changes each session)
KAGGLE_GPU_URL=
KAGGLE_GPU_TIMEOUT_SEC=180
KAGGLE_CALIBRATE_TIMEOUT_SEC=90
KAGGLE_CALIBRATE_CONNECT_TIMEOUT_SEC=8
# false = faster calibration (local openSMILE/Parselmouth only; interview GPU optional)
KAGGLE_OFFLOAD_CALIBRATION=false
KAGGLE_OFFLOAD=true
KAGGLE_OFFLOAD_SEGMENTATION=false
CANDIDATE_SPEAKER=auto
MIN_CANDIDATE_SEGMENT_SEC=4.0
DIARIZATION_NUM_SPEAKERS=2
KAGGLE_OFFLOAD_TRANSCRIPTION=true
KAGGLE_SEGMENT_MODE=pyannote
KAGGLE_FAST_MIN_CANDIDATE_SEC=3.0
KAGGLE_SKIP_ALIGN_INTERVIEW=true
KAGGLE_TRANSCRIBE_ONLY=false
KAGGLE_SEGMENT_TIMEOUT_SEC=900
KAGGLE_PARALLEL_ANSWERS=4
VIDEO_INTERVIEW_FPS=5.0
AUDIO_WINDOW_PARALLEL_WORKERS=4
ENABLE_COGNITIVE_SPONTANEITY=true
COGNITIVE_CLEAR_SPONTANEITY_MIN=0.52
COGNITIVE_CLEAR_GUIDED_MAX=0.45
SKIP_LOCAL_WHISPER_WHEN_KAGGLE=true

WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

ALERT_THRESHOLD=0.55
STD_FLOOR=0.05
EWMA_ALPHA_ATTACK=0.75
EWMA_ALPHA_DECAY=0.15

# Dual-profile contrastive engine (v5)
ENABLE_CONTRASTIVE_ENGINE=true
ENABLE_DYNAMIC_NATURAL_PROFILE=true
CONTRASTIVE_MARGIN=0.14
NATURALITY_UPDATE_THRESHOLD=0.38
NATURAL_UPDATE_MAX_SCRIPT_SIM=0.68
NATURAL_UPDATE_MIN_SPONTANEITY_SIGNALS=3
NATURAL_UPDATE_MIN_STRONG_CATEGORIES=2
NATURAL_SIMILARITY_CAP=0.82
SCRIPT_DOMINANCE_THRESHOLD=0.70
SCRIPT_DOMINANCE_BOOST=0.16
LONG_HORIZON_MIN_SEC=20
NATURAL_PROFILE_MIN_SAMPLES=3
PERSISTENCE_MIN_WINDOWS=2
TRANSITION_ALERT_THRESHOLD=0.5

# Speed (calibration) — enabled by default
FAST_CALIBRATION=true
SKIP_DIARIZATION_CALIBRATION=true
WHISPER_CALIBRATION_MODEL_SIZE=tiny
WHISPER_SKIP_ALIGN_CALIBRATION=true
VIDEO_CALIBRATION_FPS=5
PRELOAD_MODELS_ON_STARTUP=true
PRELOAD_CALIBRATION_MODEL_ONLY=true
CALIBRATION_WINDOW_PARALLEL_WORKERS=4

# Contrastive scoring weights
CONTRASTIVE_SCRIPT_WEIGHT=0.65
CONTRASTIVE_NATURAL_WEIGHT=0.35
ACOUSTIC_SENSITIVITY_SCALE=0.78
EWMA_BENIGN_MULTIPLIER=0.6

# AI interviewer + human candidate (pyannote picks candidate speaker)
# most_speech | least_speech | longest_turns
CANDIDATE_SPEAKER=longest_turns
CANDIDATE_TURN_MIN_SEC=3.0
