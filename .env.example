HF_TOKEN=your_huggingface_token_here

# Optional: path to python.exe that has whisperx installed (if auto-detect fails)
# SENTINEL_PYTHON=C:\Users\You\AppData\Local\Microsoft\WindowsApps\PythonSoftwareFoundation.Python.3.13_qbz5n2kfra8p0\python.exe
# Shared secret — must match Kaggle notebook KAGGLE_SECRET
SENTINEL_SECRET=your_shared_secret_here
KAGGLE_SECRET=your_shared_secret_here
# ngrok URL printed when kaggle_gpu_server.ipynb finishes (changes each session)
KAGGLE_GPU_URL=
KAGGLE_GPU_TIMEOUT_SEC=180
KAGGLE_CALIBRATE_TIMEOUT_SEC=90
KAGGLE_CALIBRATE_CONNECT_TIMEOUT_SEC=8
# false = faster calibration (local openSMILE/Parselmouth only; interview GPU optional)
KAGGLE_OFFLOAD_CALIBRATION=false
KAGGLE_OFFLOAD=true
KAGGLE_OFFLOAD_SEGMENTATION=false
CANDIDATE_SPEAKER=auto
MIN_CANDIDATE_SEGMENT_SEC=4.0
# Drop diarized segments whose ASR transcript has fewer words (e.g. "Sure.")
DIARIZATION_MIN_ANSWER_WORDS=5
# Skip slow local pyannote during recovery when Kaggle segmentation is on (prevents hangs)
DIARIZATION_RECOVERY_LOCAL_PYANNOTE=false
DIARIZATION_RECOVERY_MAX_ASR_SEGMENTS=16
DIARIZATION_NUM_SPEAKERS=2
KAGGLE_OFFLOAD_TRANSCRIPTION=true
KAGGLE_SEGMENT_MODE=pyannote
KAGGLE_FAST_MIN_CANDIDATE_SEC=3.0
KAGGLE_SKIP_ALIGN_INTERVIEW=true
KAGGLE_TRANSCRIBE_ONLY=false
KAGGLE_SEGMENT_TIMEOUT_SEC=900
KAGGLE_PARALLEL_ANSWERS=1
KAGGLE_TRANSCRIBE_TIMEOUT_SEC=90
KAGGLE_FALLBACK_LOCAL_ASR=true
DIARIZATION_SPEAKER_RECOVERY=false
VIDEO_INTERVIEW_FPS=5.0
AUDIO_WINDOW_PARALLEL_WORKERS=4
ENABLE_COGNITIVE_SPONTANEITY=true
COGNITIVE_CLEAR_SPONTANEITY_MIN=0.52
COGNITIVE_CLEAR_GUIDED_MAX=0.45
SKIP_LOCAL_WHISPER_WHEN_KAGGLE=true

WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

ALERT_THRESHOLD=0.55
STD_FLOOR=0.05
EWMA_ALPHA_ATTACK=0.75
EWMA_ALPHA_DECAY=0.15

# Dual-profile contrastive engine (v5)
ENABLE_CONTRASTIVE_ENGINE=true
ENABLE_DYNAMIC_NATURAL_PROFILE=true
CONTRASTIVE_MARGIN=0.14
NATURALITY_UPDATE_THRESHOLD=0.38
NATURAL_UPDATE_MAX_SCRIPT_SIM=0.68
NATURAL_UPDATE_MIN_SPONTANEITY_SIGNALS=3
NATURAL_UPDATE_MIN_STRONG_CATEGORIES=2
NATURAL_SIMILARITY_CAP=0.82
SCRIPT_DOMINANCE_THRESHOLD=0.70
SCRIPT_DOMINANCE_BOOST=0.16
LONG_HORIZON_MIN_SEC=20
NATURAL_PROFILE_MIN_SAMPLES=3
PERSISTENCE_MIN_WINDOWS=2
TRANSITION_ALERT_THRESHOLD=0.5

# Speed (calibration) — enabled by default
FAST_CALIBRATION=true
SKIP_DIARIZATION_CALIBRATION=true
WHISPER_CALIBRATION_MODEL_SIZE=tiny
WHISPER_SKIP_ALIGN_CALIBRATION=true
VIDEO_CALIBRATION_FPS=5
PRELOAD_MODELS_ON_STARTUP=true
PRELOAD_CALIBRATION_MODEL_ONLY=true
CALIBRATION_WINDOW_PARALLEL_WORKERS=4

# Contrastive scoring weights
CONTRASTIVE_SCRIPT_WEIGHT=0.65
CONTRASTIVE_NATURAL_WEIGHT=0.35
ACOUSTIC_SENSITIVITY_SCALE=0.78
EWMA_BENIGN_MULTIPLIER=0.6

# SCRIPT profile purification + NATURAL strengthening
SCRIPT_PROFILE_PURIFY_CALIBRATION=true
SCRIPT_COGNITIVE_METRIC_WEIGHT=1.0
SCRIPT_LINGUISTIC_DELIVERY_WEIGHT=0.32
SCRIPT_ACOUSTIC_DELIVERY_WEIGHT=0.24
ENABLE_FLUENT_NATURAL_PROFILE_LEARNING=true
FLUENT_NATURAL_UPDATE_SCRIPT_CEILING=0.62
FLUENT_NATURAL_LEARNING_MIN_SPONTANEITY=0.40
FLUENT_STYLE_LEAK_FACTOR=0.85
COGNITIVE_TURBULENCE_SCRIPT_DAMPEN=0.22
PREPARED_BEHAVIOR_SOFTEN_TO_AMBIGUOUS=true
GUIDANCE_DOMINANCE_MIN_PROBABLE=0.58
GUIDANCE_DOMINANCE_STRICT_FOR_WEAK=0.66
REHEARSAL_PROTECTION_MIN_SPONTANEITY=0.34
REHEARSAL_PROTECTION_MAX_GUIDED=0.62
REHEARSAL_PROTECTION_MIN_TURBULENCE=0.20
REHEARSAL_PROTECTION_MIN_RECOVERY=0.12
SEMANTIC_GUIDEDNESS_MIN_PROBABLE=0.54
ESSAY_LIKE_GUIDEDNESS_MIN=0.46
GENERALIZATION_CONSENSUS_MIN_SCORE=0.56
GENERALIZATION_DIVERSITY_MIN_SIGNALS=4
GENERALIZATION_SAFETY_MAX_HUMAN_VARIABILITY=0.58
GENERALIZATION_ENABLE_UNCERTAINTY_PRESERVE=true
SEMANTIC_EFFORT_DECOUPLING_PROBABLE_MIN=0.58
SEMANTIC_ACOUSTIC_COHERENCE_CLEAR_MIN=0.56
PRETOKEN_ADAPTATION_CLEAR_MIN=0.42

# Cognitive Sourcing Inference (internal vs externally guided cognition)
ENABLE_COGNITIVE_SOURCING=true
PREPARED_INTERNALIZATION_PROTECTION=true

# Intra-individual behavioral modeling (person-relative baseline)
ENABLE_INTRA_INDIVIDUAL=true
INTRA_INDIVIDUAL_AUTHORITY=false
INTRA_INDIVIDUAL_PRESERVE_UNCERTAINTY=true
INTRA_INDIVIDUAL_SESSION_REFINEMENT=true
PERSONAL_BASELINE_EARLY_ANSWERS=2
SESSION_P_PRIOR=0.5
SESSION_P_PROBABLE_MIN=0.62
SESSION_SOURCING_MIN_STRONG_WINDOWS=2
COLD_START_PROBABLE_MIN_STRONG_WINDOWS=4
SOURCING_LIKELIHOOD_MARGIN=0.08
SOURCING_SOFT_EVIDENCE_MIN=0.38
SOURCING_EXTERNAL_PROMOTE_MIN=0.52
SESSION_EXTERNAL_LIKELIHOOD_PROBABLE_MIN=0.55
SESSION_EXTERNAL_LIKELIHOOD_AMBIGUOUS_MIN=0.45
SESSION_UNIFORMITY_PROMOTE_MIN=0.52

# Transcript-based specificity (person-independent)
ENABLE_SEMANTIC_SPECIFICITY=true
WEIGHT_SPECIFICITY=0.35
SPECIFICITY_CLEAR_MIN=0.42
SPECIFICITY_GENERIC_PROBABLE_MIN=0.58
MEMORIZED_TECHNICAL_PROBABLE_MIN=0.42
PERSONAL_NARRATIVE_CLEAR_MIN=0.35
SESSION_FEEDFORWARD_P_MIN=0.55
SESSION_FEEDFORWARD_MIN_ANSWERS=2
CONTENT_UNIFORMITY_SUSPICIOUS_MIN=0.52
MIN_CALIBRATION_WINDOWS=5
MIN_SCRIPT_PROFILE_SAMPLES=3
EWMA_BEHAVIORAL_TRACK_SCALE=0.45

PRELOAD_DIARIZATION_ON_STARTUP=true
WHISPER_SKIP_ALIGN_INTERVIEW=true
# Set true to skip slow whisper-timestamped re-runs when fillers are missing
WHISPER_DISABLE_FILLER_FALLBACK=false
# Faster than /analyze_batch when GPU score channel is unused
KAGGLE_TRANSCRIBE_ONLY=true
# Local pyannote = accurate; Kaggle fast VAD = much faster segmentation
# KAGGLE_OFFLOAD_SEGMENTATION=true
# KAGGLE_SEGMENT_MODE=fast

# AI interviewer + human candidate (pyannote picks candidate speaker)
# most_speech | least_speech | longest_turns | responder | auto
CANDIDATE_SPEAKER=auto
CANDIDATE_TURN_MIN_SEC=3.0

# Optional LLM judge — tie-breaker on AMBIGUOUS answers only (off by default)
ENABLE_LLM_JUDGE=false
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=SentinEL
# OPENROUTER_HTTP_REFERER=http://127.0.0.1:8765
ANTHROPIC_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# OpenRouter examples (add :free for zero-cost tier; ~200 req/day on free models):
# LLM_PROVIDER=openrouter
# LLM_MODEL=openai/gpt-oss-20b:free          # recommended free judge (faster, better JSON than 120b)
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
# LLM_MODEL=openai/gpt-oss-120b:free
# LLM_MODEL=openrouter/free                   # auto-pick any free model
# OPENROUTER_API_KEY=sk-or-...
# LLM_JUDGE_TIMEOUT_SEC=60
ANTHROPIC_BASE_URL=https://api.anthropic.com
OLLAMA_BASE_URL=http://127.0.0.1:11434
LLM_JUDGE_PROMOTE_MIN=0.72
LLM_JUDGE_CLEAR_MAX=0.28
LLM_JUDGE_MIN_CONFIDENCE=MEDIUM
LLM_JUDGE_TIMEOUT_SEC=30
LLM_JUDGE_MAX_ANSWERS=0
LLM_JUDGE_MIN_WORDS=8
LLM_JUDGE_TEMPERATURE=0
LLM_JUDGE_MAX_TOKENS=512
